<launch>
    <!-- Launches the arduino & raspberry pi connection node and establishes communication -->
    <include file="$(find arduino_pi_comm)/launch/arduino_base.launch"/>
    
    <!-- Robot Urdf and robot_state_publisher are set -->
    <param command="$(find xacro)/xacro $(find robomuse_description)/urdf/robomuse.xacro" name="robot_description"/>
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen"/>
    
    <!-- Launch the RPLidar node and establishes communication -->
    <include file="$(find robomuse_bringup)/launch/robomuse_lidar.launch"/>
</launch>

