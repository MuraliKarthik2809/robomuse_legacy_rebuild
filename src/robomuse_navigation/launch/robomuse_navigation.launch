<launch>

  <!-- Arguments -->
  <arg name="base_frame_id" default="base_link"/>
  <arg name="open_rviz" default="true"/>
  <arg name="move_forward_only" default="false"/>

  <!-- Map file -->
  <arg name="map_file" default="$(find robomuse_navigation)/maps/robomuse_map.yaml"/>

  <!-- Map server -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_file)" />

  <!-- AMCL -->
  <include file="$(find robomuse_navigation)/launch/amcl.launch"/>

  <!-- move_base -->
  <include file="$(find robomuse_navigation)/launch/move_base.launch">
    <arg name="base_frame_id" value="$(arg base_frame_id)" />
    <arg name="move_forward_only" value="$(arg move_forward_only)" />
  </include>

  <!-- RViz -->
  <group if="$(arg open_rviz)">
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find robomuse_navigation)/rviz/robomuse_navigation.rviz"/>
  </group>

</launch>
