<?xml version="1.0"?>

<launch>

  <!-- Choose SLAM method -->
  <arg name="slam_method" default="gmapping"/>

  <!-- Base frame -->
  <arg name="base_frame_id" default="base_link"/>

  <!-- Use simulation time as true for simulation-->
  <arg name="use_sim_time" default="false"/>
  <param name="use_sim_time" value="$(arg use_sim_time)"/> 

  <!-- Gmapping -->
  <include file="$(find robomuse_slam)/launch/robomuse_gmapping.launch"
           if="$(eval slam_method == 'gmapping')">
    <arg name="base_frame_id" value="$(arg base_frame_id)"/>
  </include>

  <!-- Cartographer -->
  <include file="$(find robomuse_slam)/launch/robomuse_cartographer.launch"
           if="$(eval slam_method == 'cartographer')">
    <arg name="base_frame_id" value="$(arg base_frame_id)"/>
  </include>

  <!-- RViz -->
  <node pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find robomuse_slam)/rviz/mapping.rviz"
        output="screen" />

</launch>